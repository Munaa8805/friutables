<% if (notFound) { %>
    <div class="container-fluid page-header py-5">
        <h1 class="text-center text-white display-6">Product</h1>
        <ol class="breadcrumb justify-content-center mb-0">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item"><a href="/shop">Shop</a></li>
            <li class="breadcrumb-item active text-white">Not found</li>
        </ol>
    </div>
    <div class="container py-5 text-center">
        <p class="lead text-muted mb-4">This product could not be found.</p>
        <a href="/shop" class="btn btn-primary rounded-pill px-4">Back to shop</a>
    </div>
    <% } else { %>
        <% const imgs=Array.isArray(product.images) ? product.images : (product.images ? [product.images] : []); const
            imgUrls=imgs.filter(Boolean).map(function (f) { return (typeof f==='string' && f.indexOf('http')===0) ? f
            : '/img/' + String(f).replace(/^\//, '' ); }); if (!imgUrls.length) imgUrls.push('/img/fruite-item-5.jpg');
            const catName=product.category && product.category.name ? product.category.name : 'Product' ; %>
            <div class="container-fluid page-header py-5">
                <h1 class="text-center text-white display-6 text-capitalize">
                    <%= product.name %>
                </h1>
                <ol class="breadcrumb justify-content-center mb-0">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a href="/shop">Shop</a></li>
                    <li class="breadcrumb-item active text-white text-capitalize">
                        <%= product.name %>
                    </li>
                </ol>
            </div>

            <div class="container-fluid py-5">
                <div class="container py-5">
                    <div class="row g-4 align-items-start">
                        <div class="col-lg-6">
                            <div id="productDetailGallery" class="product-detail-gallery position-relative"
                                data-current-index="0" data-gallery-count="<%= imgUrls.length %>">
                                <div class="product-detail-main">
                                    <% if (imgUrls.length===1) { %>
                                        <a href="<%= imgUrls[0] %>" data-lightbox="product-<%= product._id %>"
                                            data-title="<%= product.name %>"
                                            class="d-block h-100 text-decoration-none product-detail-main-lightbox">
                                            <img id="productMainImg" src="<%= imgUrls[0] %>"
                                                class="product-detail-main-img" alt="<%= product.name %>">
                                        </a>
                                        <% } else { %>
                                            <button type="button"
                                                class="product-detail-gallery-opener btn p-0 border-0 bg-transparent w-100 h-100"
                                                aria-label="Open image gallery (use arrows to browse photos)">
                                                <img id="productMainImg" src="<%= imgUrls[0] %>"
                                                    class="product-detail-main-img" alt="<%= product.name %>">
                                            </button>
                                            <% } %>
                                </div>
                                <% if (imgUrls.length> 1) { %>
                                    <div class="product-detail-thumbs d-flex gap-2 mt-3" role="group"
                                        aria-label="Product photo gallery">
                                        <% imgUrls.forEach(function (url, idx) { %>
                                            <button type="button"
                                                class="btn product-thumb p-0 border rounded-2 overflow-hidden <%= idx === 0 ? 'border-primary border-2' : 'border-secondary' %>"
                                                data-img="<%= url %>" data-gallery-index="<%= idx %>"
                                                aria-label="Show image <%= idx + 1 %> of <%= imgUrls.length %>"
                                                aria-pressed="<%= idx === 0 ? 'true' : 'false' %>">
                                                <img src="<%= url %>" class="product-detail-thumb-img" alt=""
                                                    loading="<%= idx === 0 ? 'eager' : 'lazy' %>">
                                            </button>
                                            <% }) %>
                                    </div>
                                    <div class="product-gallery-lightbox-anchors" aria-hidden="true">
                                        <% imgUrls.forEach(function (url, idx) { %>
                                            <a href="<%= url %>" data-lightbox="product-<%= product._id %>"
                                                data-title="<%= product.name %> — <%= idx + 1 %> / <%= imgUrls.length %>"
                                                id="product-gallery-anchor-<%= idx %>" tabindex="-1">Photo <%= idx + 1
                                                    %></a>
                                            <% }) %>
                                    </div>
                                    <% } %>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <span class="badge bg-secondary text-capitalize mb-2">
                                <%= catName %>
                            </span>
                            <h1 class="display-6 text-primary mb-3 text-capitalize">
                                <%= product.name %>
                            </h1>
                            <p class="fs-3 fw-bold text-dark mb-2">$<%= Number(product.price).toFixed(2) %> <span
                                        class="fs-6 fw-normal text-muted">/ kg</span></p>
                            <% if (typeof product.stock !=='undefined' ) { %>
                                <p class="text-muted mb-4"><strong>In stock:</strong>
                                    <%= product.stock %> kg
                                </p>
                                <% } %>
                                    <% if (typeof product.rating !=='undefined' && product.rating> 0) { %>
                                        <p class="mb-4"><span class="text-secondary">★</span>
                                            <%= Number(product.rating).toFixed(1) %>
                                                <% if (product.numReviews) { %><span class="text-muted">(<%=
                                                            product.numReviews %> reviews)</span>
                                                    <% } %>
                                        </p>
                                        <% } %>
                                            <div class="mb-4">
                                                <h5 class="mb-2">Description</h5>
                                                <p class="text-muted mb-0" style="white-space: pre-line;">
                                                    <%= product.description %>
                                                </p>
                                            </div>
                                            <div class="d-flex flex-wrap gap-3 align-items-center">
                                                <a href="/shop<%= product.category && product.category._id ? '?category=' + product.category._id : '' %>"
                                                    class="btn btn-outline-secondary rounded-pill px-4">More in this
                                                    category</a>
                                                <a href="/shop" class="btn btn-outline-secondary rounded-pill px-4">←
                                                    All products</a>
                                                <form action="/cart/add" method="post" class="m-0">
                                                    <input type="hidden" name="productId" value="<%= product._id %>">
                                                    <input type="hidden" name="qty" value="1">
                                                    <input type="hidden" name="redirectTo"
                                                        value="<%= currentUrl || ('/product/' + product._id) %>">
                                                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                                                        <i class="fa fa-shopping-bag me-2"></i> Add to cart
                                                    </button>
                                                </form>
                                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <% if (relatedProducts && relatedProducts.length) { %>
                <div class="container-fluid bg-light py-5 border-top related-products-section">
                    <div class="container py-4">
                        <h2 class="mb-0 text-primary">More from <span class="text-capitalize">
                                <%= catName %>
                            </span></h2>
                        <div class="owl-carousel related-products-carousel mt-4">
                            <% relatedProducts.forEach(function (rel) { %>
                                <% var rImgs=Array.isArray(rel.images) ? rel.images : (rel.images ? [rel.images] : []);
                                    var rFile=rImgs.length && rImgs[0] ? rImgs[0] : 'fruite-item-5.jpg' ; var
                                    rSrc=(typeof rFile==='string' && rFile.indexOf('http')===0) ? rFile : '/img/' +
                                    String(rFile).replace(/^\//, '' ); var rDesc=rel.description || '' ; var
                                    rBadge=rel.category && rel.category.name ? rel.category.name : catName; %>
                                    <div class="h-100">
                                        <div
                                            class="rounded position-relative fruite-item shop-product-card related-product-card w-100 h-100 d-flex flex-column">
                                            <a href="/product/<%= rel._id %>" class="stretched-link"
                                                aria-label="View <%= rel.name %>"></a>
                                            <div class="fruite-img flex-shrink-0">
                                                <img src="<%= rSrc %>" class="img-fluid w-100 rounded-top"
                                                    alt="<%= rel.name %>">
                                            </div>
                                            <div class="text-white bg-secondary px-2 py-1 rounded position-absolute text-capitalize z-1 small"
                                                style="top: 8px; left: 8px;">
                                                <%= rBadge %>
                                            </div>
                                            <div
                                                class="p-3 border border-secondary border-top-0 rounded-bottom flex-grow-1 d-flex flex-column bg-white">
                                                <h5 class="mb-1 text-capitalize">
                                                    <%= rel.name %>
                                                </h5>
                                                <p class="small text-muted mb-2 related-product-desc">
                                                    <%= rDesc %>
                                                </p>
                                                <%- include('./partials/product-card-rating', { rating: rel.rating,
                                                    numReviews: rel.numReviews, cardRatingClass: 'small text-muted mb-2'
                                                    }) %>
                                                    <p class="text-dark fw-bold mb-0 mt-auto">$<%=
                                                            Number(rel.price).toFixed(2) %> / kg</p>
                                            </div>
                                        </div>
                                    </div>
                                    <% }) %>
                        </div>
                    </div>
                </div>
                <% } %>
                    <% } %>