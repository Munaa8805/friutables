<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Shop</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a href="#">Home</a></li>
        <li class="breadcrumb-item"><a href="#">Pages</a></li>
        <li class="breadcrumb-item active text-white">Shop</li>
    </ol>
</div>
<!-- Single Page Header End -->


<!-- Fruits Shop Start-->
<div class="container-fluid fruite py-5">
    <div class="container py-5">
        <h1 class="mb-4">Fresh fruits shop</h1>
        <div class="row g-4">
            <div class="col-lg-12">
                <div class="row g-4">
                    <div class="col-xl-3">
                        <div class="input-group w-100 mx-auto d-flex">
                            <input type="search" class="form-control p-3" placeholder="keywords"
                                aria-describedby="search-icon-1">
                            <span id="search-icon-1" class="input-group-text p-3"><i class="fa fa-search"></i></span>
                        </div>
                    </div>
                    <div class="col-6"></div>
                    <div class="col-xl-3">
                        <div class="bg-light ps-3 py-3 rounded d-flex justify-content-between mb-4">
                            <label for="fruits">Default Sorting:</label>
                            <select id="fruits" name="fruitlist" class="border-0 form-select-sm bg-light me-3"
                                form="fruitform">
                                <option value="volvo">Nothing</option>
                                <option value="saab">Popularity</option>
                                <option value="opel">Organic</option>
                                <option value="audi">Fantastic</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="row g-4">
                    <div class="col-lg-3">
                        <% function shopUrl(categoryId, maxPrice, pageNum) { var parts=[]; if (categoryId) {
                            parts.push('category=' + encodeURIComponent(String(categoryId))); } if (maxPrice !== null &&
                            typeof maxPrice !== 'undefined' && maxPrice !== '') { parts.push('maxPrice=' +
                            encodeURIComponent(String(maxPrice))); } if (pageNum > 1) { parts.push('page=' + pageNum); }
                            return parts.length ? '/shop?' + parts.join('&') : '/shop'; } %>
                            <div class="row g-4">
                                <div class="col-lg-12">
                                    <div class="mb-3">
                                        <h4>Categories</h4>
                                        <ul class="list-unstyled fruite-categorie">
                                            <li>
                                                <a href="<%= shopUrl(null, selectedMaxPrice, 1) %>"
                                                    class="<%= !selectedCategoryId ? 'fw-bold text-primary' : '' %>"><i
                                                        class="fas fa-apple-alt me-2"></i>All</a>
                                            </li>
                                            <% (categories || []).forEach(function (cat) { %>
                                                <% const isActive=typeof selectedCategoryId !=='undefined' &&
                                                    selectedCategoryId && String(cat._id)===String(selectedCategoryId);
                                                    %>
                                                    <li>
                                                        <div class="d-flex justify-content-between fruite-name">
                                                            <a href="<%= shopUrl(cat._id, selectedMaxPrice, 1) %>"
                                                                class="<%= isActive ? 'fw-bold text-primary' : '' %>"><i
                                                                    class="fas fa-apple-alt me-2"></i><span
                                                                    class="text-capitalize">
                                                                    <%= cat.name %>
                                                                </span></a>
                                                            <span>(<%= cat.productCount %>)</span>
                                                        </div>
                                                    </li>
                                                    <% }) %>
                                        </ul>
                                    </div>
                                </div>
                                <div class="col-lg-12">
                                    <div class="mb-3">
                                        <h4>Additional</h4>
                                        <div class="mb-2">
                                            <input type="radio" class="me-2" id="Categories-1" name="Categories-1"
                                                value="Beverages">
                                            <label for="Categories-1"> Organic</label>
                                        </div>
                                        <div class="mb-2">
                                            <input type="radio" class="me-2" id="Categories-2" name="Categories-1"
                                                value="Beverages">
                                            <label for="Categories-2"> Fresh</label>
                                        </div>
                                        <div class="mb-2">
                                            <input type="radio" class="me-2" id="Categories-3" name="Categories-1"
                                                value="Beverages">
                                            <label for="Categories-3"> Sales</label>
                                        </div>
                                        <div class="mb-2">
                                            <input type="radio" class="me-2" id="Categories-4" name="Categories-1"
                                                value="Beverages">
                                            <label for="Categories-4"> Discount</label>
                                        </div>
                                        <div class="mb-2">
                                            <input type="radio" class="me-2" id="Categories-5" name="Categories-1"
                                                value="Beverages">
                                            <label for="Categories-5"> Expired</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-12">
                                    <h4 class="mb-3">Featured products</h4>
                                    <div class="d-flex align-items-center justify-content-start">
                                        <div class="rounded me-4" style="width: 100px; height: 100px;">
                                            <img src="img/featur-1.jpg" class="img-fluid rounded" alt="">
                                        </div>
                                        <div>
                                            <h6 class="mb-2">Big Banana</h6>
                                            <div class="d-flex mb-2">
                                                <i class="fa fa-star text-secondary"></i>
                                                <i class="fa fa-star text-secondary"></i>
                                                <i class="fa fa-star text-secondary"></i>
                                                <i class="fa fa-star text-secondary"></i>
                                                <i class="fa fa-star"></i>
                                            </div>
                                            <div class="d-flex mb-2">
                                                <h5 class="fw-bold me-2">2.99 $</h5>
                                                <h5 class="text-danger text-decoration-line-through">4.11 $</h5>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-start">
                                        <div class="rounded me-4" style="width: 100px; height: 100px;">
                                            <img src="img/featur-2.jpg" class="img-fluid rounded" alt="">
                                        </div>
                                        <div>
                                            <h6 class="mb-2">Big Banana</h6>
                                            <div class="d-flex mb-2">
                                                <i class="fa fa-star text-secondary"></i>
                                                <i class="fa fa-star text-secondary"></i>
                                                <i class="fa fa-star text-secondary"></i>
                                                <i class="fa fa-star text-secondary"></i>
                                                <i class="fa fa-star"></i>
                                            </div>
                                            <div class="d-flex mb-2">
                                                <h5 class="fw-bold me-2">2.99 $</h5>
                                                <h5 class="text-danger text-decoration-line-through">4.11 $</h5>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-start">
                                        <div class="rounded me-4" style="width: 100px; height: 100px;">
                                            <img src="img/default.jpg" class="img-fluid rounded" alt="">
                                        </div>
                                        <div>
                                            <h6 class="mb-2">Big Banana</h6>
                                            <div class="d-flex mb-2">
                                                <i class="fa fa-star text-secondary"></i>
                                                <i class="fa fa-star text-secondary"></i>
                                                <i class="fa fa-star text-secondary"></i>
                                                <i class="fa fa-star text-secondary"></i>
                                                <i class="fa fa-star"></i>
                                            </div>
                                            <div class="d-flex mb-2">
                                                <h5 class="fw-bold me-2">2.99 $</h5>
                                                <h5 class="text-danger text-decoration-line-through">4.11 $</h5>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-center my-4">
                                        <a href="#"
                                            class="btn border border-secondary px-4 py-3 rounded-pill text-primary w-100">Vew
                                            More</a>
                                    </div>
                                </div>
                                <div class="col-lg-12">
                                    <div class="position-relative">
                                        <img src="img/banner-fruits.jpg" class="img-fluid w-100 rounded" alt="">
                                        <div class="position-absolute"
                                            style="top: 50%; right: 10px; transform: translateY(-50%);">
                                            <h3 class="text-secondary fw-bold">Fresh <br> Fruits <br> Banner</h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                    </div>
                    <div class="col-lg-9">
                        <% function shopPageUrl(pageNum) { return shopUrl(selectedCategoryId, selectedMaxPrice,
                            pageNum); } %>
                            <div class="row g-4 align-items-stretch justify-content-center">
                                <% if (!(products || []).length) { %>
                                    <div class="col-12 text-center py-5">
                                        <p class="text-muted mb-0">No products found.</p>
                                    </div>
                                    <% } %>
                                        <% (products || []).forEach(function (prod) { %>
                                            <% var imgFile=(prod.images && prod.images.length && prod.images[0]) ?
                                                prod.images[0] : 'fruite-item-5.jpg' ; var imgSrc=(typeof
                                                imgFile==='string' && imgFile.indexOf('http')===0) ? imgFile : '/img/' +
                                                String(imgFile).replace(/^\//, '' ); var desc=prod.description || '' ;
                                                var badge=(prod.category && prod.category.name) ? prod.category.name
                                                : 'Product' ; %>
                                                <div class="col-md-6 col-lg-6 col-xl-4 d-flex">
                                                    <div
                                                        class="rounded position-relative fruite-item shop-product-card w-100 d-flex flex-column">
                                                        <a href="/product/<%= prod._id %>" class="stretched-link"
                                                            aria-label="View <%= prod.name %>"></a>
                                                        <div class="fruite-img flex-shrink-0">
                                                            <img src="<%= imgSrc %>" class="img-fluid w-100 rounded-top"
                                                                alt="<%= prod.name %>">
                                                        </div>
                                                        <div class="text-white bg-secondary px-3 py-1 rounded position-absolute text-capitalize z-1"
                                                            style="top: 10px; left: 10px;">
                                                            <%= badge %>
                                                        </div>
                                                        <div
                                                            class="p-4 border border-secondary border-top-0 rounded-bottom flex-grow-1 d-flex flex-column">
                                                            <h4 class="mb-2">
                                                                <%= prod.name %>
                                                            </h4>
                                                            <p class="shop-product-desc text-muted mb-3">
                                                                <%= desc %>
                                                            </p>
                                                            <%- include('./partials/product-card-rating', { rating: prod.rating, numReviews: prod.numReviews, cardRatingClass: 'text-muted small mb-2' }) %>
                                                            <div
                                                                class="d-flex justify-content-between flex-lg-wrap gap-2 mt-auto position-relative z-1">
                                                                <p class="text-dark fs-5 fw-bold mb-0">$<%=
                                                                        Number(prod.price).toFixed(2) %> / kg</p>
                                                                <form action="/cart/add" method="post" class="m-0">
                                                                    <input type="hidden" name="productId" value="<%= prod._id %>">
                                                                    <input type="hidden" name="qty" value="1">
                                                                    <input type="hidden" name="redirectTo" value="<%= currentUrl || '/shop' %>">
                                                                    <button type="submit"
                                                                        class="btn border border-secondary rounded-pill px-3 text-primary"><i
                                                                            class="fa fa-shopping-bag me-2 text-primary"></i>
                                                                        Add to cart</button>
                                                                </form>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <% }) %>
                                                    <% if (typeof totalPages !=='undefined' && totalPages> 1) { %>
                                                        <div class="col-12">
                                                            <div
                                                                class="pagination d-flex justify-content-center flex-wrap gap-1 mt-5">
                                                                <% if (typeof currentPage !=='undefined' && currentPage>
                                                                    1) { %>
                                                                    <a href="<%= shopPageUrl(currentPage - 1) %>"
                                                                        class="rounded"
                                                                        aria-label="Previous">&laquo;</a>
                                                                    <% } else { %>
                                                                        <span
                                                                            class="rounded text-muted user-select-none">&laquo;</span>
                                                                        <% } %>
                                                                            <% for (var p=1; p <=totalPages; p++) { %>
                                                                                <a href="<%= shopPageUrl(p) %>"
                                                                                    class="rounded <%= (typeof currentPage !== 'undefined' && p === currentPage) ? 'active' : '' %>">
                                                                                    <%= p %>
                                                                                </a>
                                                                                <% } %>
                                                                                    <% if (typeof currentPage
                                                                                        !=='undefined' && currentPage <
                                                                                        totalPages) { %>
                                                                                        <a href="<%= shopPageUrl(currentPage + 1) %>"
                                                                                            class="rounded"
                                                                                            aria-label="Next">&raquo;</a>
                                                                                        <% } else { %>
                                                                                            <span
                                                                                                class="rounded text-muted user-select-none">&raquo;</span>
                                                                                            <% } %>
                                                            </div>
                                                        </div>
                                                        <% } %>
                            </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Fruits Shop End-->