<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Cart</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a href="#">Home</a></li>
        <li class="breadcrumb-item"><a href="#">Pages</a></li>
        <li class="breadcrumb-item active text-white">Cart</li>
    </ol>
</div>
<!-- Single Page Header End -->


<!-- Cart Page Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        <% const items = cartItems || []; %>
        <% if (!items.length) { %>
            <div class="text-center py-5">
                <p class="lead text-muted mb-4">Your cart is empty.</p>
                <a href="/shop" class="btn btn-primary rounded-pill px-4">Start shopping</a>
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th scope="col">Products</th>
                            <th scope="col">Name</th>
                            <th scope="col">Price</th>
                            <th scope="col">Quantity</th>
                            <th scope="col">Total</th>
                            <th scope="col">Handle</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% items.forEach(function (item) { %>
                            <tr>
                                <th scope="row">
                                    <div class="d-flex align-items-center">
                                        <img src="<%= item.imageSrc %>" class="img-fluid me-4 rounded-circle"
                                            style="width: 80px; height: 80px; object-fit: cover;" alt="<%= item.name %>">
                                    </div>
                                </th>
                                <td>
                                    <a href="/product/<%= item.productId %>" class="mb-0 mt-4 d-inline-block text-dark">
                                        <%= item.name %>
                                    </a>
                                </td>
                                <td>
                                    <p class="mb-0 mt-4">$<%= item.unitPrice.toFixed(2) %></p>
                                </td>
                                <td>
                                    <div class="d-inline-flex align-items-center gap-1 mt-4">
                                        <form action="/cart/update" method="post" class="m-0 d-inline">
                                            <input type="hidden" name="productId" value="<%= item.productId %>">
                                            <input type="hidden" name="action" value="dec">
                                            <button class="btn btn-sm btn-minus rounded-circle bg-light border" type="submit">
                                                <i class="fa fa-minus"></i>
                                            </button>
                                        </form>
                                        <input type="text"
                                            class="form-control form-control-sm text-center border-0 bg-light"
                                            style="width: 40px;"
                                            value="<%= item.qty %>" readonly>
                                        <form action="/cart/update" method="post" class="m-0 d-inline">
                                            <input type="hidden" name="productId" value="<%= item.productId %>">
                                            <input type="hidden" name="action" value="inc">
                                            <button class="btn btn-sm btn-plus rounded-circle bg-light border" type="submit">
                                                <i class="fa fa-plus"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                                <td>
                                    <p class="mb-0 mt-4">$<%= item.lineTotal.toFixed(2) %></p>
                                </td>
                                <td>
                                    <form action="/cart/remove" method="post" class="m-0">
                                        <input type="hidden" name="productId" value="<%= item.productId %>">
                                        <button class="btn btn-md rounded-circle bg-light border mt-4" type="submit">
                                            <i class="fa fa-times text-danger"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <div class="mt-4 d-flex justify-content-end">
                <form action="/cart/clear" method="post" class="m-0">
                    <button class="btn btn-outline-danger rounded-pill px-4 py-2" type="submit">Clear cart</button>
                </form>
            </div>
        <% } %>
        <div class="row g-4 justify-content-end">
            <div class="col-8"></div>
            <div class="col-sm-8 col-md-7 col-lg-6 col-xl-4">
                <div class="bg-light rounded">
                    <div class="p-4">
                        <h1 class="display-6 mb-4">Cart <span class="fw-normal">Total</span></h1>
                        <div class="d-flex justify-content-between mb-4">
                            <h5 class="mb-0 me-4">Subtotal:</h5>
                            <p class="mb-0">$<%= Number(subtotal || 0).toFixed(2) %></p>
                        </div>
                        <div class="d-flex justify-content-between mb-4">
                            <h5 class="mb-0 me-4">Tax (15%):</h5>
                            <p class="mb-0">$<%= Number(tax || 0).toFixed(2) %></p>
                        </div>
                        <div class="d-flex justify-content-between">
                            <h5 class="mb-0 me-4">Shipping</h5>
                            <div class="">
                                <p class="mb-0">Flat rate: $<%= Number(shipping || 0).toFixed(2) %></p>
                            </div>
                        </div>
                        <p class="mb-0 text-end">Shipping calculated at checkout.</p>
                    </div>
                    <div class="py-4 mb-4 border-top border-bottom d-flex justify-content-between">
                        <h5 class="mb-0 ps-4 me-4">Total</h5>
                        <p class="mb-0 pe-4">$<%= Number(total || 0).toFixed(2) %></p>
                    </div>
                    <a href="/checkout" class="btn border-secondary rounded-pill px-4 py-3 text-primary text-uppercase mb-4 ms-4">
                        Proceed Checkout
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Cart Page End -->