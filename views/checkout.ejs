<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Checkout</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a href="#">Home</a></li>
        <li class="breadcrumb-item"><a href="#">Pages</a></li>
        <li class="breadcrumb-item active text-white">Checkout</li>
    </ol>
</div>
<!-- Single Page Header End -->


<!-- Checkout Page Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        <h1 class="mb-4">Billing details</h1>
        <% const items = cartItems || []; %>
        <% if (success) { %>
            <div class="alert alert-success" role="alert">
                Order placed successfully. Order ID: <strong><%= orderId %></strong>
            </div>
        <% } %>
        <% if (error) { %>
            <div class="alert alert-danger" role="alert"><%= error %></div>
        <% } %>
        <% if (!items.length) { %>
            <div class="text-center py-5">
                <p class="lead text-muted mb-4">Your cart is empty. Add products before checkout.</p>
                <a href="/shop" class="btn btn-primary rounded-pill px-4">Go to shop</a>
            </div>
        <% } else { %>
        <form action="/checkout" method="post">
            <div class="row g-5">
                <div class="col-md-12 col-lg-6 col-xl-7">

                    <div class="form-item">
                        <label class="form-label my-3">User Name<sup>*</sup></label>
                        <input type="text" class="form-control" value="<%= user && user.name ? user.name : '' %>" readonly>
                    </div>
                    <div class="form-item">
                        <label class="form-label my-3">Address <sup>*</sup></label>
                        <input type="text" name="address" class="form-control" placeholder="House Number Street Name" required>
                    </div>
                    <div class="form-item">
                        <label class="form-label my-3">Town/City<sup>*</sup></label>
                        <input type="text" name="city" class="form-control" required>
                    </div>
                    <div class="form-item">
                        <label class="form-label my-3">State<sup>*</sup></label>
                        <input type="text" name="state" class="form-control" required>
                    </div>
                    <div class="form-item">
                        <label class="form-label my-3">Country<sup>*</sup></label>
                        <input type="text" name="country" class="form-control" required>
                    </div>
                    <div class="form-item">
                        <label class="form-label my-3">Postcode/Zip<sup>*</sup></label>
                        <input type="text" name="zip" class="form-control" required>
                    </div>
                    <div class="form-item">
                        <label class="form-label my-3">Mobile<sup>*</sup></label>
                        <input type="tel" name="phone" class="form-control" required>
                    </div>
                    <div class="form-item">
                        <label class="form-label my-3">Email Address<sup>*</sup></label>
                        <input type="email" name="email" class="form-control" value="<%= user && user.email ? user.email : '' %>" required>
                    </div>

                    <div class="form-item">
                        <label class="form-label my-3">Order Notes<sup>*</sup></label>
                        <textarea name="notes" class="form-control" spellcheck="false" cols="30" rows="11"
                            placeholder="Order notes" required></textarea>
                    </div>
                </div>
                <div class="col-md-12 col-lg-6 col-xl-5">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th scope="col">Products</th>
                                    <th scope="col">Name</th>
                                    <th scope="col">Price</th>
                                    <th scope="col">Quantity</th>
                                    <th scope="col">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% items.forEach(function(item) { %>
                                    <tr>
                                        <th scope="row">
                                            <div class="d-flex align-items-center mt-2">
                                                <img src="<%= item.imageSrc %>" class="img-fluid rounded-circle"
                                                    style="width: 72px; height: 72px; object-fit: cover;" alt="<%= item.name %>">
                                            </div>
                                        </th>
                                        <td class="py-5"><%= item.name %></td>
                                        <td class="py-5">$<%= item.unitPrice.toFixed(2) %></td>
                                        <td class="py-5"><%= item.qty %></td>
                                        <td class="py-5">$<%= item.lineTotal.toFixed(2) %></td>
                                    </tr>
                                <% }) %>
                                <tr>
                                    <th scope="row">
                                    </th>
                                    <td class="py-5"></td>
                                    <td class="py-5"></td>
                                    <td class="py-5">
                                        <p class="mb-0 text-dark py-3">Subtotal</p>
                                    </td>
                                    <td class="py-5">
                                        <div class="py-3 border-bottom border-top">
                                            <p class="mb-0 text-dark">$<%= Number(subtotal || 0).toFixed(2) %></p>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row">
                                    </th>
                                    <td class="py-5">
                                        <p class="mb-0 text-dark py-4">Tax (15%)</p>
                                    </td>
                                    <td class="py-5"></td>
                                    <td class="py-5"></td>
                                    <td class="py-5">
                                        <p class="mb-0 text-dark">$<%= Number(tax || 0).toFixed(2) %></p>
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row">
                                    </th>
                                    <td class="py-5">
                                        <p class="mb-0 text-dark py-4">Shipping</p>
                                    </td>
                                    <td class="py-5"></td>
                                    <td class="py-5"></td>
                                    <td class="py-5">
                                        <p class="mb-0 text-dark">$<%= Number(shipping || 0).toFixed(2) %></p>
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row">
                                    </th>
                                    <td class="py-5">
                                        <p class="mb-0 text-dark text-uppercase py-3">TOTAL</p>
                                    </td>
                                    <td class="py-5"></td>
                                    <td class="py-5"></td>
                                    <td class="py-5">
                                        <div class="py-3 border-bottom border-top">
                                            <p class="mb-0 text-dark">$<%= Number(total || 0).toFixed(2) %></p>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="row g-4 text-center align-items-center justify-content-center border-bottom py-3">
                        <div class="col-12">
                            <div class="form-check text-start my-3">
                                <input type="radio" class="form-check-input bg-primary border-0" id="pay-cash"
                                    name="paymentMethod" value="cash" checked>
                                <label class="form-check-label" for="pay-cash">Cash on Delivery</label>
                            </div>
                        </div>
                    </div>
                    <div class="row g-4 text-center align-items-center justify-content-center border-bottom py-3">
                        <div class="col-12">
                            <div class="form-check text-start my-3">
                                <input type="radio" class="form-check-input bg-primary border-0" id="pay-card"
                                    name="paymentMethod" value="card">
                                <label class="form-check-label" for="pay-card">Card</label>
                            </div>
                        </div>
                    </div>
                    <div class="row g-4 text-center align-items-center justify-content-center border-bottom py-3">
                        <div class="col-12">
                            <div class="form-check text-start my-3">
                                <input type="radio" class="form-check-input bg-primary border-0" id="pay-bank"
                                    name="paymentMethod" value="bank transfer">
                                <label class="form-check-label" for="pay-bank">Bank Transfer</label>
                            </div>
                        </div>
                    </div>
                    <div class="row g-4 text-center align-items-center justify-content-center pt-4">
                        <button type="submit"
                            class="btn border-secondary py-3 px-4 text-uppercase w-100 text-primary">Place
                            Order</button>
                    </div>
                </div>
            </div>
        </form>
        <% } %>
    </div>
</div>
<!-- Checkout Page End -->